# ReEscape Protocol environment example
# Copy this file to `.env` and fill in the values you actually use.
#
# Note:
# - `WsPort`, `HttpPort`, and `Token` currently use this exact mixed-case spelling
#   because the code reads them with those names.
# - `AI_PROFILE` + `AI_CONFIG_FILE` is the preferred way to manage model settings.
# - `AI_KEY` / `AI_BASEURL` / `AI_MODEL` also remain valid as fallback inputs.

# Base connection settings
HOSTADD=127.0.0.1
WsPort=3001
HttpPort=8088
Token=your_onebot_access_token
TARGETID=987654321
CHARACTER=default

# AI profile selection
AI_PROFILE=default
AI_CONFIG_FILE=./config/ai_profiles.json

# Direct AI fallback values
AI_KEY=your_ai_api_key
AI_BASEURL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Prompt and generation settings
AI_PROMPT=
AI_TEMPERATURE=1.0
AI_MAX_TOKENS=2000
AI_TIMEOUT=30
AI_RETRY_COUNT=3
AI_RATE_LIMIT=20
AI_TOP_P=0.9

# Conversation scheduling
ENABLE_NATURAL_SCHEDULER=true
ENABLE_EMOTIONAL_MEMORY=true
ENABLE_ONLY_LONG_CHAT=false
MESSAGE_AGGREGATE_IDLE_WINDOW_MS=2000
MESSAGE_AGGREGATE_MAX_WINDOW_MS=10000
MESSAGE_AGGREGATE_MAX_MESSAGES=5
ACTIVE_HOURS=9,10,11,14,15,16,19,20,21
SLEEP_HOURS=0,1,2,3,4,5,6,7,8,22,23
BASE_INTERVAL=45
RANDOM_FACTOR=0.5

# Runtime logging and storage
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_FORMAT=text
LOG_ENABLE_COLOR=true
REQUEST_ID_HEADER=X-Request-ID
ENABLE_HEALTH_ENDPOINT=true
ENABLE_METRICS=true
METRICS_PATH=/metrics
LOG_DIR=./logs
DATA_DIR=./data
